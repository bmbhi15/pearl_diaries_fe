{
  "expo": {
    "name": "Pearl Diaries",
    "slug": "pearl-diaries",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "platforms": ["ios", "android", "web"],
    "ios": {
      "supportsTabletMode": false,
      "bundleIdentifier": "com.pearldiaries.app"
    },
    "android": {
      "package": "com.pearldiaries.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Pearl Diaries needs access to your photos and videos so you can share festival moments."
        }
      ]
    ]
  }
}
